{
    "$schema": "https://biomejs.dev/schemas/1.7.1/schema.json",
    "organizeImports": {
        "enabled": false
    },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noBannedTypes": "off",
                "noForEach": "off",
                "noStaticOnlyClass": "off",
                "noThisInStatic": "off",
                "useRegexLiterals": "off"
            },
            "correctness": {
                "noUnusedVariables": "error",
                "noVoidTypeReturn": "off"
            },
            "performance": {
                "noDelete": "off"
            },
            "style": {
                "useImportType": "off",
                "useNodejsImportProtocol": "off",
                "noNonNullAssertion": "off",
                "noParameterAssign": "off",
                "noUselessElse": "off",
                "useExportType": "off"
            },
            "suspicious": {
                "noAssignInExpressions": "off",
                "noConfusingVoidType": "off",
                "noConsoleLog": "off",
                "noExplicitAny": "off",
                "noUnsafeDeclarationMerging": "off"
            }
        }
    },
    "json": {
        "formatter": {
            "enabled": false
        }
    },
    "files": {
        "ignore": ["dist", "tests", "types", "static/lib/"]
    }
}
