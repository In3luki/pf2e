{
    "$schema": "https://biomejs.dev/schemas/1.7.1/schema.json",
    "organizeImports": {
        "enabled": false
    },
    "formatter": {
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "complexity": {
                "noBannedTypes": "off",
                "noForEach": "off",
                "noStaticOnlyClass": "off",
                "noThisInStatic": "off",
                "useRegexLiterals": "off"
            },
            "correctness": {
                "noConstructorReturn": "off",
                "noUnnecessaryContinue": "off",
                "noVoidTypeReturn": "off"
            },
            "performance": {
                "noAccumulatingSpread": "off",
                "noDelete": "off"
            },
            "style": {
                "useImportType": "off",
                "useNodejsImportProtocol": "off",
                "noNonNullAssertion": "off",
                "noParameterAssign": "off",
                "noUselessElse": "off",
                "noVar": "error",
                "useExportType": "off"
            },
            "suspicious": {
                "noApproximativeNumericConstant": "off",
                "noAssignInExpressions": "off",
                "noConfusingVoidType": "off",
                "noConsoleLog": "off",
                "noEmptyInterface": "off",
                "noUnsafeDeclarationMerging": "off"
            }
        },
        "ignore": ["packs"]
    },
    "json": {
        "formatter": {
            "enabled": false
        },
        "parser": {
            "allowComments": true
        }
    },
    "files": {
        "ignore": ["dist", "static/lib/"]
    },
    "overrides": [
        {
            "include": ["types"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noRedeclare": "off"
                    }
                }
            }
        },
        {
            "include": ["tests"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noThenProperty": "off"
                    }
                }
            }
        }
    ]
}
